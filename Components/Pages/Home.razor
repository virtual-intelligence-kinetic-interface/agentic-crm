@page "/"
@rendermode InteractiveServer
@inject CrmService CrmSvc
@inject AnthropicService AiSvc
@inject IJSRuntime JS
@implements IDisposable
@using System.Text.Json

<PageTitle>Agentic CRM</PageTitle>

<div class="min-h-screen bg-slate-50 text-slate-900 font-sans antialiased flex flex-col">

    <!-- HEADER -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-30 px-6 py-4 shadow-xs">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <div class="flex items-center gap-3">
                    <span class="p-2.5 bg-indigo-600 text-white rounded-xl shadow-md shadow-indigo-100">
                        <i class="bi bi-layers text-xl"></i>
                    </span>
                    <div>
                        <h1 class="text-xl font-bold tracking-tight text-slate-900">Agentic CRM Workspace</h1>
                        <p class="text-xs text-slate-500 font-mono">Parallel Autonomous Agent Orchestrator</p>
                    </div>
                </div>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4 w-full md:w-auto">
                <div class="bg-slate-50 px-4 py-2 rounded-xl border border-slate-200">
                    <span class="text-[10px] text-slate-500 font-mono uppercase block">Total Contacts</span>
                    <div class="flex items-center gap-2">
                        <i class="bi bi-people text-slate-600"></i>
                        <span class="text-lg font-bold text-slate-950">@leads.Count</span>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-2 rounded-xl border border-slate-200">
                    <span class="text-[10px] text-slate-500 font-mono uppercase block">High-Fit Ratio</span>
                    <div class="flex items-center gap-2">
                        <i class="bi bi-shield-check text-emerald-600"></i>
                        <span class="text-lg font-bold text-slate-950">@QualifiedRatio%</span>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-2 rounded-xl border border-slate-200">
                    <span class="text-[10px] text-slate-500 font-mono uppercase block">Deals Succeeded</span>
                    <div class="flex items-center gap-2">
                        <i class="bi bi-graph-up-arrow text-indigo-600"></i>
                        <span class="text-lg font-bold text-slate-950">@WonCount</span>
                    </div>
                </div>
                <div class="bg-slate-50 px-4 py-2 rounded-xl border border-slate-200">
                    <span class="text-[10px] text-slate-500 font-mono uppercase block">Automation Runs</span>
                    <div class="flex items-center gap-2">
                        <i class="bi bi-terminal text-purple-600"></i>
                        <span class="text-lg font-bold text-slate-950">@TotalRunCount</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main class="flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 grid grid-cols-1 lg:grid-cols-12 gap-6">

        <!-- GUIDE BANNER -->
        @if (showInstructionDoc)
        {
            <div class="lg:col-span-12 bg-linear-to-r from-indigo-900 via-slate-900 to-indigo-950 text-white rounded-2xl p-6 shadow-lg border border-indigo-800 relative overflow-hidden">
                <div class="absolute top-0 right-0 w-64 h-64 bg-indigo-500/10 rounded-full blur-3xl" />
                <div class="absolute -bottom-10 left-10 w-48 h-48 bg-purple-500/10 rounded-full blur-3xl" />
                <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
                    <div class="space-y-2 max-w-2xl">
                        <div class="flex items-center gap-2">
                            <span class="bg-indigo-500/30 text-indigo-300 text-[10px] font-mono font-bold px-2 py-0.5 rounded-full border border-indigo-700/50">
                                👋 NOOB-FRIENDLY WORKSPACE GUIDE
                            </span>
                            <span class="inline-block h-2 w-2 rounded-full bg-emerald-400 animate-pulse" />
                        </div>
                        <h2 class="text-xl md:text-2xl font-bold tracking-tight">Welcome to Your Parallel AI Agent Workspace!</h2>
                        <p class="text-slate-300 text-xs md:text-sm leading-relaxed">
                            Normally, doing market research, writing custom sales pitches, and mapping client support roadmaps can take hours.
                            In this workspace, <strong>three distinct AI agents work simultaneously</strong> to do this work for you in seconds.
                        </p>
                    </div>
                    <button @onclick="RunInstantDemo"
                            class="bg-emerald-500 hover:bg-emerald-400 active:scale-95 text-slate-950 font-bold px-5 py-3 rounded-xl text-xs flex items-center gap-2 shadow-lg transition-all self-stretch md:self-auto justify-center">
                        <i class="bi bi-stars animate-bounce"></i>
                        ✨ Auto-Select & Run Instant Demo
                    </button>
                    <button @onclick="() => showInstructionDoc = false"
                            class="absolute top-3 right-3 p-1.5 hover:bg-white/10 rounded-lg text-slate-400 hover:text-white transition">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="mt-6 pt-5 border-t border-slate-800 grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="p-3 bg-white/5 rounded-xl border border-white/15">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="h-5 w-5 rounded-full bg-indigo-500 text-white flex items-center justify-center font-bold text-xs">1</span>
                            <h4 class="text-xs font-bold text-white">Pick Your Contact</h4>
                        </div>
                        <p class="text-[11px] text-slate-300 leading-normal">Select a person from the <strong>Prospect Directory</strong>. Each contact represents a real business opportunity.</p>
                    </div>
                    <div class="p-3 bg-white/5 rounded-xl border border-white/15">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="h-5 w-5 rounded-full bg-emerald-500 text-slate-950 flex items-center justify-center font-bold text-xs">2</span>
                            <h4 class="text-xs font-bold text-white">Deploy Parallel Orchestrator</h4>
                        </div>
                        <p class="text-[11px] text-slate-300 leading-normal">Click <strong>Deploy AI Parallel Agents</strong> and watch three independent agents analyze your subject simultaneously.</p>
                    </div>
                    <div class="p-3 bg-white/5 rounded-xl border border-white/15">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="h-5 w-5 rounded-full bg-purple-500 text-white flex items-center justify-center font-bold text-xs">3</span>
                            <h4 class="text-xs font-bold text-white">Inspect and Copy Products</h4>
                        </div>
                        <p class="text-[11px] text-slate-300 leading-normal">Browse customized SDR drafts, marketing tags, and success checklists, then hit Copy to use them.</p>
                    </div>
                </div>
            </div>
        }

        <!-- LEFT COLUMN -->
        <section class="lg:col-span-5 flex flex-col gap-6">
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col h-[750px]">
                <div class="flex justify-between items-center px-4 py-3.5 border-b border-slate-200 bg-slate-50/50 rounded-t-2xl">
                    <div class="flex gap-2">
                        <button @onclick='() => activeTab = "leads"'
                                class="@TabClass("leads") px-3 py-1.5 rounded-lg text-xs font-semibold tracking-tight transition-all">
                            <i class="bi bi-people mr-1"></i>Prospect Directory
                        </button>
                        <button @onclick='() => activeTab = "pipeline"'
                                class="@TabClass("pipeline") px-3 py-1.5 rounded-lg text-xs font-semibold tracking-tight transition-all">
                            <i class="bi bi-layers mr-1"></i>Interactive Kanban
                        </button>
                    </div>
                    <button @onclick="() => showAddModal = true"
                            class="p-1 px-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-medium flex items-center gap-1 transition">
                        <i class="bi bi-plus-lg"></i> Add Lead
                    </button>
                </div>

                <!-- LEADS LIST -->
                @if (activeTab == "leads")
                {
                    <div class="flex-1 overflow-y-auto p-4 space-y-3">
                        @if (!leads.Any())
                        {
                            <div class="text-center py-16 text-slate-400">
                                <i class="bi bi-people text-4xl opacity-40 block mb-2"></i>
                                <p class="text-sm font-medium">No leads currently in system.</p>
                                <button @onclick="() => showAddModal = true" class="mt-3 text-xs text-indigo-600 font-semibold underline">Provision first lead</button>
                            </div>
                        }
                        else
                        {
                            @foreach (var lead in leads)
                            {
                                var isSelected = selectedLeadId == lead.Id;
                                var isEvaluated = lead.SalesScore.HasValue;
                                <div @key="lead.Id" @onclick="() => selectedLeadId = lead.Id"
                                     class="p-4 rounded-xl border transition-all duration-200 cursor-pointer @(isSelected ? "bg-indigo-50/50 border-indigo-400 shadow-sm ring-1 ring-indigo-100" : "bg-white hover:bg-slate-50 border-slate-200")">
                                    <div class="flex justify-between items-start gap-2">
                                        <div>
                                            <h3 class="font-bold text-slate-900 text-sm">@lead.Name</h3>
                                            <p class="text-xs text-slate-500 font-medium flex items-center gap-1 my-0.5">
                                                <i class="bi bi-building text-slate-400"></i>
                                                @lead.Company &bull; <span class="text-slate-600">@lead.Title</span>
                                            </p>
                                        </div>
                                        <span class="text-[10px] font-mono font-bold px-2 py-0.5 rounded-full @StatusBadgeClass(lead.Status)">@lead.Status</span>
                                    </div>
                                    <div class="mt-2 py-1.5 px-2 bg-slate-50 rounded-lg border border-slate-100 text-xs text-slate-600">
                                        <span class="font-semibold block text-[10px] text-slate-500 uppercase font-mono">Interest Details</span>
                                        <span class="line-clamp-1">@lead.CoreProductInterest</span>
                                    </div>
                                    <div class="mt-3 pt-2 border-t border-slate-100 flex justify-between items-center gap-2">
                                        <div class="flex flex-wrap gap-1">
                                            @foreach (var tag in lead.Tags.Take(2))
                                            {
                                                <span class="bg-slate-100 text-slate-600 text-[10px] font-medium px-1.5 rounded">@tag</span>
                                            }
                                            @if (lead.Tags.Count > 2)
                                            {
                                                <span class="text-[9px] text-slate-400 font-mono">+@(lead.Tags.Count - 2)</span>
                                            }
                                        </div>
                                        <div class="flex items-center gap-2">
                                            @if (isEvaluated)
                                            {
                                                <div class="flex items-center gap-1.5">
                                                    <span class="text-[10px] font-bold text-slate-500 font-mono uppercase">Sales Fit</span>
                                                    <span class="text-xs font-mono font-bold px-1.5 rounded-md @ScoreBadgeClass(lead.SalesScore ?? 0)">@lead.SalesScore%</span>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-[10px] font-mono text-slate-500 bg-slate-100 px-2 py-0.5 rounded-sm">Pending AI Run</span>
                                            }
                                            <button @onclick:stopPropagation="true" @onclick="() => HandleDeleteLead(lead.Id)"
                                                    class="p-1 hover:bg-rose-50 text-slate-400 hover:text-rose-600 rounded transition" title="Delete">
                                                <i class="bi bi-trash text-sm"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                }

                <!-- KANBAN VIEW -->
                @if (activeTab == "pipeline")
                {
                    <div class="flex-1 overflow-y-auto p-4 space-y-4">
                        <p class="text-[11px] text-slate-500 font-mono">&bull; Use the dropdown inside each card to move prospects across pipeline stages.</p>
                        @foreach (var stage in pipelineStages)
                        {
                            var stageLeads = leads.Where(l => l.Status == stage).ToList();
                            <div class="bg-slate-50 rounded-xl p-3 border border-slate-200">
                                <div class="flex justify-between items-center mb-2 px-1">
                                    <span class="text-xs font-bold text-slate-900 font-mono flex items-center gap-1.5">
                                        <span class="h-2 w-2 rounded-full bg-slate-400"></span>@stage
                                    </span>
                                    <span class="text-[10px] font-mono bg-slate-200 text-slate-600 px-2 py-0.5 rounded-full">@stageLeads.Count</span>
                                </div>
                                <div class="space-y-2">
                                    @if (!stageLeads.Any())
                                    {
                                        <div class="text-slate-400 text-[10px] py-2 text-center border border-dashed border-slate-200 rounded-lg">No contacts in @stage</div>
                                    }
                                    else
                                    {
                                        @foreach (var lead in stageLeads)
                                        {
                                            <div @key="lead.Id" @onclick="() => selectedLeadId = lead.Id"
                                                 class="p-3 bg-white border rounded-lg shadow-2xs cursor-pointer transition @(selectedLeadId == lead.Id ? "border-indigo-500 ring-1 ring-indigo-50" : "border-slate-200")">
                                                <div class="flex justify-between items-start gap-2">
                                                    <span class="text-xs font-bold text-slate-900">@lead.Name</span>
                                                    <select @onchange="e => UpdateLeadStatus(lead.Id, e.Value?.ToString() ?? string.Empty)"
                                                            @onclick:stopPropagation="true"
                                                            class="text-[9px] font-mono bg-slate-50 border border-slate-300 rounded px-1 py-0.5 text-slate-600">
                                                        @foreach (var s in pipelineStages)
                                                        {
                                                            <option value="@s" selected="@(lead.Status == s)">@s</option>
                                                        }
                                                    </select>
                                                </div>
                                                <span class="text-[10px] text-slate-500 block">@lead.Company</span>
                                                @if (lead.SalesScore.HasValue)
                                                {
                                                    <div class="mt-1.5 pt-1.5 border-t border-slate-100 flex justify-between items-center">
                                                        <span class="text-[9px] font-mono text-slate-500">Sales Fit:</span>
                                                        <span class="text-[10px] font-bold text-indigo-600 font-mono">@lead.SalesScore%</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="p-3 border-t border-slate-200 bg-slate-50/50 rounded-b-2xl flex justify-between items-center text-[10px] text-slate-500 font-mono">
                    <span>Database status: Operational</span>
                    <button @onclick="RefreshData" class="flex items-center gap-1 hover:text-slate-800 transition">
                        <i class="bi bi-arrow-clockwise"></i> Sync
                    </button>
                </div>
            </div>
        </section>

        <!-- RIGHT COLUMN -->
        <section class="lg:col-span-7 flex flex-col gap-6">
            @if (SelectedLead is not null)
            {
                var sel = SelectedLead;
                <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-6 flex flex-col gap-6">

                    <!-- Lead Header -->
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center pb-5 border-b border-slate-200 gap-4">
                        <div>
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-bold text-slate-400 font-mono tracking-wider uppercase">Active CRM Subject</span>
                                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                            </div>
                            <h2 class="text-2xl font-bold text-slate-900 tracking-tight">@sel.Name</h2>
                            <p class="text-sm text-slate-500 font-semibold">@sel.Title @@ <span class="text-indigo-600 underline">@sel.Company</span></p>
                        </div>
                        <div class="flex gap-2 w-full md:w-auto">
                            @if (sel.SalesScore.HasValue)
                            {
                                <button @onclick="() => ResetLeadEvaluation(sel.Id)"
                                        class="p-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-xl text-xs font-semibold flex items-center gap-1 transition">
                                    <i class="bi bi-arrow-clockwise"></i> Reset
                                </button>
                            }
                            <button @onclick="() => RunParallelAgents(sel.Id)" disabled="@agentRunning"
                                    class="flex-1 md:flex-none p-2.5 px-5 text-white rounded-xl text-xs font-bold flex items-center justify-center gap-2 shadow-md transition-all @(agentRunning ? "bg-slate-400 cursor-not-allowed" : "bg-indigo-600 hover:bg-indigo-700")">
                                @if (agentRunning)
                                {
                                    <i class="bi bi-arrow-clockwise animate-spin"></i>
                                    <span>Parallel Execution Active...</span>
                                }
                                else
                                {
                                    <i class="bi bi-play-fill"></i>
                                    <span>Deploy AI Parallel Agents</span>
                                }
                            </button>
                        </div>
                    </div>

                    <!-- Meta Grid -->
                    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 p-4 bg-slate-50 border border-slate-200 rounded-xl">
                        <div>
                            <span class="text-[10px] text-slate-500 font-mono uppercase block">Estimated Budget</span>
                            <span class="text-xs font-bold text-slate-800 flex items-center mt-0.5"><i class="bi bi-currency-dollar text-slate-400"></i>@sel.Budget</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-500 font-mono uppercase block">Industry Sector</span>
                            <span class="text-xs font-bold text-slate-800 mt-0.5 block">@sel.Industry</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-500 font-mono uppercase block">Company Size</span>
                            <span class="text-xs font-bold text-slate-800 mt-0.5 block">@sel.CompanySize</span>
                        </div>
                        <div>
                            <span class="text-[10px] text-slate-500 font-mono uppercase block">Source</span>
                            <span class="text-xs font-bold text-slate-800 mt-0.5 block">@sel.Source</span>
                        </div>
                    </div>

                    <div>
                        <span class="text-[10px] text-slate-500 font-mono uppercase block mb-1">CRM Logged Interaction</span>
                        <p class="text-xs text-slate-700 bg-indigo-50/20 border border-indigo-100 rounded-lg p-3 italic leading-relaxed">
                            "@(sel.Notes ?? "No logged notes provided. Agents will evaluate based on core interest characteristics.")"
                        </p>
                    </div>

                    <!-- Agent Panels -->
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-xs font-extrabold text-slate-900 tracking-wider uppercase font-mono">Parallel Agent Execution Orbits</h3>
                            @if (!AiSvc.IsActive)
                            {
                                <span class="text-[10px] text-amber-700 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full font-mono font-medium flex items-center gap-1">
                                    <i class="bi bi-question-circle"></i> Demo Simulation Mode
                                </span>
                            }
                            else
                            {
                                <span class="text-[10px] text-emerald-700 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full font-mono font-medium flex items-center gap-1">
                                    <i class="bi bi-stars"></i> Claude Active
                                </span>
                            }
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            @foreach (var agentDef in agentDefs)
                            {
                                var state = agentStates[agentDef.Id];
                                var hasData = agentDef.Id == "sales" ? sel.SalesScore.HasValue
                                            : agentDef.Id == "marketing" ? sel.MarketingPitch != null
                                            : sel.SuccessChecklist != null;
                                <div class="border rounded-xl p-4 transition duration-300 relative overflow-hidden @(agentRunning ? "border-indigo-400 bg-slate-50/50" : hasData ? "border-emerald-200 bg-white" : "border-slate-200 bg-white")">
                                    @if (agentRunning)
                                    {
                                        <div class="absolute top-0 left-0 w-full h-1 bg-indigo-100">
                                            <div class="h-full bg-indigo-600 transition-all duration-300 animate-pulse" style="width: @(state.Progress)%"></div>
                                        </div>
                                    }
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="h-2.5 w-2.5 rounded-full @(agentRunning ? "bg-indigo-600 animate-ping" : hasData ? "bg-emerald-600" : "bg-slate-300")"></span>
                                        <span class="text-xs font-bold text-slate-800">@agentDef.Name</span>
                                    </div>
                                    <p class="text-[10px] text-slate-500 leading-normal mb-3 min-h-8">@agentDef.RoleTitle</p>
                                    @if (agentRunning)
                                    {
                                        <div class="space-y-1">
                                            <span class="text-[9px] font-mono font-semibold text-indigo-700 block">Processing... @(state.Progress)%</span>
                                            <div class="w-full bg-slate-100 h-1.5 rounded-full overflow-hidden">
                                                <div class="bg-indigo-600 h-full rounded-full" style="width: @(state.Progress)%"></div>
                                            </div>
                                        </div>
                                    }
                                    else if (hasData)
                                    {
                                        <div class="flex items-center gap-1 text-[10px] text-emerald-700 font-mono font-bold bg-emerald-50 py-1 px-1.5 rounded border border-emerald-100 w-fit">
                                            <i class="bi bi-check-lg text-emerald-600"></i> Completed Successfully
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-[10px] text-slate-400 font-mono">Idle - Awaiting Deploy</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Agent Output Vault -->
                    @if (sel.SalesScore.HasValue)
                    {
                        <div class="border border-slate-200 rounded-xl overflow-hidden mt-2">
                            <div class="bg-slate-50 border-b border-slate-200 px-4 py-3 flex justify-between items-center">
                                <span class="text-xs font-bold text-slate-900 font-mono uppercase">Agent Compilation Vault</span>
                                <span class="text-[10px] text-slate-500 font-mono">Generated Parallel Modules</span>
                            </div>
                            <div class="divide-y divide-slate-100">

                                <!-- Sales -->
                                <div class="p-4 space-y-2">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs font-bold text-emerald-700 flex items-center gap-1.5 font-mono">
                                            <i class="bi bi-person-check"></i> [SDR OUTCOME] &bull; Score: @sel.SalesScore%
                                        </span>
                                        <button @onclick="() => CopyToClipboard(sel.SalesEmailDraft ?? string.Empty)"
                                                class="text-[10px] text-indigo-600 hover:text-indigo-800 flex items-center gap-1 font-semibold">
                                            <i class="bi bi-clipboard"></i> Copy Draft
                                        </button>
                                    </div>
                                    <div class="bg-emerald-50/20 p-2 border border-emerald-100/50 rounded-lg text-[11px] text-slate-650 italic">
                                        <strong>Agent Strategic Thoughts:</strong> "@sel.SalesThought"
                                    </div>
                                    <pre class="bg-slate-900 text-slate-100 p-3 rounded-lg font-mono text-[11px] overflow-x-auto whitespace-pre-wrap max-h-48 shadow-inner">@sel.SalesEmailDraft</pre>
                                </div>

                                <!-- Marketing -->
                                <div class="p-4 space-y-2">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs font-bold text-indigo-700 flex items-center gap-1.5 font-mono">
                                            <i class="bi bi-sliders"></i> [MARKETING OUTCOME] &bull; Pitch Line
                                        </span>
                                        <button @onclick="() => CopyToClipboard(sel.MarketingCampaign ?? string.Empty)"
                                                class="text-[10px] text-indigo-600 hover:text-indigo-800 flex items-center gap-1 font-semibold">
                                            <i class="bi bi-clipboard"></i> Copy Campaign
                                        </button>
                                    </div>
                                    <div class="bg-indigo-50/30 p-2 border border-indigo-100/30 rounded-lg text-xs">
                                        <strong>Headline Tagline Pitch:</strong>
                                        <span class="font-bold text-slate-900 block mt-1">"@sel.MarketingPitch"</span>
                                    </div>
                                    <div class="p-2.5 bg-slate-50 border border-slate-200 rounded-lg text-[11px] text-slate-700">
                                        <strong>Campaign Strategy:</strong>
                                        <p class="mt-1 whitespace-pre-line leading-relaxed">@sel.MarketingCampaign</p>
                                    </div>
                                </div>

                                <!-- Success -->
                                <div class="p-4 space-y-2">
                                    <div class="flex justify-between items-center">
                                        <span class="text-xs font-bold text-purple-700 flex items-center gap-1.5 font-mono">
                                            <i class="bi bi-check-square"></i> [SUCCESS OUTCOME] &bull; Onboarding Track
                                        </span>
                                        <button @onclick="() => CopyToClipboard(sel.SuccessResponse ?? string.Empty)"
                                                class="text-[10px] text-indigo-600 hover:text-indigo-800 flex items-center gap-1 font-semibold">
                                            <i class="bi bi-clipboard"></i> Copy Welcome Letter
                                        </button>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-2">
                                        @if (sel.SuccessChecklist != null)
                                        {
                                            @for (int i = 0; i < sel.SuccessChecklist.Count; i++)
                                            {
                                                var idx = i;
                                                <div class="p-2 bg-purple-50/50 border border-purple-100 rounded-lg flex items-start gap-1.5">
                                                    <span class="h-4 w-4 rounded-full bg-purple-100 text-purple-700 flex items-center justify-center text-[9px] font-bold flex-shrink-0 mt-0.5">@(idx+1)</span>
                                                    <span class="text-[10px] text-slate-600 leading-snug">@sel.SuccessChecklist[idx]</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                    <div class="p-3 bg-slate-50 border border-slate-200 rounded-lg">
                                        <strong class="text-xs">Direct Onboarding Email:</strong>
                                        <p class="mt-1 whitespace-pre-line text-[11px] text-slate-700 leading-relaxed">@sel.SuccessResponse</p>
                                    </div>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="bg-white border border-slate-200 rounded-2xl p-16 text-center text-slate-400">
                    <i class="bi bi-people text-4xl opacity-50 block mb-2"></i>
                    <p>Select a lead from the directory or provision a new one.</p>
                </div>
            }

            <!-- LOG PANEL -->
            <div class="bg-slate-900 text-slate-100 rounded-2xl p-6 border border-slate-800 flex flex-col h-[380px] shadow-lg">
                <div class="flex justify-between items-center border-b border-slate-800 pb-3 mb-4">
                    <div class="flex items-center gap-2">
                        <span class="p-1 px-2.5 bg-slate-800 text-indigo-400 border border-slate-700 rounded-md font-mono text-xs">LOGS</span>
                        <h3 class="text-sm font-bold tracking-tight text-white">Parallel Reasoning Process & Queue Log</h3>
                    </div>
                    <span class="text-[10px] text-slate-400 font-mono flex items-center gap-1">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span> Live Stream Feed
                    </span>
                </div>
                <div class="flex-1 overflow-y-auto space-y-3 font-mono text-[11px] pr-2">
                    @if (!logs.Any())
                    {
                        <div class="text-center py-12 text-slate-500">Waiting for active agent runs to output parallel trace reasoning streams...</div>
                    }
                    else
                    {
                        @foreach (var log in logs)
                        {
                            var agentColor = log.AgentId == "marketing" ? "text-indigo-400" : log.AgentId == "success" ? "text-purple-400" : "text-emerald-400";
                            var typeColor = log.Type == "reasoning" ? "text-amber-400" : log.Type == "output" ? "text-indigo-300" : log.Type == "error" ? "text-rose-500" : "text-slate-400";
                            <div @key="log.Id" class="p-2 border-b border-slate-800/50 space-y-1 hover:bg-slate-800/20 rounded">
                                <div class="flex justify-between">
                                    <span class="text-[10px] text-slate-500">@log.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                    <span class="text-[10px] font-bold @typeColor">@log.Type.ToUpper()</span>
                                </div>
                                <div>
                                    <span class="font-bold mr-1.5 @agentColor">[@log.AgentId.ToUpper()]</span>
                                    <span class="text-slate-200 text-xs">@log.Message</span>
                                    <span class="text-[10px] text-slate-500 ml-1">(subject: @log.LeadName)</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-white border-t border-slate-200 mt-12 py-6 text-center text-xs text-slate-500">
        <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-4">
            <p>&copy; 2026 Agentic CRM System &bull; Dedicated Multi-Agent Parallel Pipeline Execution Platform</p>
            <div class="flex gap-4">
                <span class="text-slate-400">Model: claude-opus-4-8</span>
                <span class="text-slate-400">&bull;</span>
                <span class="text-slate-400">Blazor Server .NET 8</span>
            </div>
        </div>
    </footer>

    <!-- ADD LEAD MODAL -->
    @if (showAddModal)
    {
        <div class="fixed inset-0 bg-slate-900/60 flex items-center justify-center z-50 p-4" @onclick="() => showAddModal = false">
            <div class="bg-white max-w-lg w-full rounded-2xl shadow-xl border border-slate-200 max-h-[90vh] flex flex-col" @onclick:stopPropagation="true">
                <div class="p-4 px-6 border-b border-slate-100 flex justify-between items-center">
                    <div>
                        <h3 class="text-base font-bold text-slate-900">Provision Fresh CRM Subject</h3>
                        <p class="text-[11px] text-slate-500 font-mono">Insert lead dimensions for parallel agent assessment</p>
                    </div>
                    <button @onclick="() => showAddModal = false" class="p-1 text-slate-400 hover:text-slate-600 rounded transition">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <EditForm Model="newLeadModel" OnValidSubmit="HandleAddLead" class="flex-1 overflow-y-auto p-6 space-y-4 text-xs">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Full Name *</label>
                            <InputText @bind-Value="newLeadModel.Name" placeholder="e.g. John Doe" required class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                        </div>
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Company *</label>
                            <InputText @bind-Value="newLeadModel.Company" placeholder="e.g. Acme Corp" required class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Corporate Title</label>
                            <InputText @bind-Value="newLeadModel.Title" placeholder="e.g. VP Operations" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                        </div>
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Email Address *</label>
                            <InputText @bind-Value="newLeadModel.Email" placeholder="name@company.com" required class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Estimated Budget</label>
                            <InputText @bind-Value="newLeadModel.Budget" placeholder="$50,000 / year" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                        </div>
                        <div>
                            <label class="block text-slate-600 font-semibold mb-1">Industry</label>
                            <InputSelect @bind-Value="newLeadModel.Industry" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden">
                                <option value="Technology">Technology / SaaS</option>
                                <option value="FinTech">Finance / Payments</option>
                                <option value="Biotech">Biotech / AgTech</option>
                                <option value="Healthcare">Healthcare Operations</option>
                                <option value="Logistics">Supply Chain & Logistics</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div>
                        <label class="block text-slate-600 font-semibold mb-1">Core Product Interest *</label>
                        <InputTextArea @bind-Value="newLeadModel.CoreProductInterest" rows="2" placeholder="e.g. Enterprise SOC-2 workflows or offline telemetry analytics" required class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                    </div>
                    <div>
                        <label class="block text-slate-600 font-semibold mb-1">Strategic Context / Notes</label>
                        <InputTextArea @bind-Value="newLeadModel.Notes" rows="2" placeholder="Met on trade show. Wants to displace legacy Salesforce by Q4." class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                    </div>
                    <div>
                        <label class="block text-slate-600 font-semibold mb-1">Tags (comma-separated)</label>
                        <input type="text" @bind="newLeadTagsInput" placeholder="AWS Partner, Quick Buy, Enterprise" class="w-full bg-slate-50 border border-slate-300 rounded-lg p-2 text-xs focus:ring-1 focus:ring-indigo-500 focus:outline-hidden" />
                    </div>
                    <div class="pt-4 border-t border-slate-100 flex justify-end gap-2">
                        <button type="button" @onclick="() => showAddModal = false" class="p-2 px-4 bg-slate-100 hover:bg-slate-200 rounded-lg text-slate-700 font-medium transition">Cancel</button>
                        <button type="submit" class="p-2 px-5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-bold shadow-md transition">Save Lead</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

</div>

@code {
    private List<Lead> leads = new();
    private List<AgentLog> logs = new();
    private string? selectedLeadId;
    private string activeTab = "leads";
    private bool agentRunning = false;
    private bool showInstructionDoc = true;
    private bool showAddModal = false;

    private record AgentDef(string Id, string Name, string RoleTitle);
    private record AgentState(string Status = "idle", int Progress = 0);

    private readonly AgentDef[] agentDefs = {
        new("sales", "SDR Evaluation Agent", "Lead Qualification & Custom Outreach Drafts"),
        new("marketing", "Creative Growth Agent", "Multichannel Campaign Sequencing"),
        new("success", "Customer Success Coach", "Proactive Onboarding Strategy & Retention Checklists")
    };

    private Dictionary<string, AgentState> agentStates = new()
    {
        ["sales"] = new(), ["marketing"] = new(), ["success"] = new()
    };

    private readonly string[] pipelineStages = { "New", "Qualified", "Nurturing", "Proposal", "Won", "Challenged" };

    // Form model
    private Lead newLeadModel = new() { Industry = "Technology", CompanySize = "50-100 employees", Budget = "$25,000 / year" };
    private string newLeadTagsInput = "";

    private Lead? SelectedLead => leads.FirstOrDefault(l => l.Id == selectedLeadId) ?? leads.FirstOrDefault();
    private int QualifiedRatio => leads.Count > 0 ? (int)Math.Round(leads.Count(l => (l.SalesScore ?? 0) >= 80) * 100.0 / leads.Count) : 0;
    private int WonCount => leads.Count(l => l.Status == "Won");
    private int TotalRunCount => logs.Count(l => l.Type == "output");

    protected override void OnInitialized()
    {
        RefreshData();
        CrmSvc.OnChange += HandleDataChange;
    }

    private void RefreshData()
    {
        leads = CrmSvc.Leads.ToList();
        logs = CrmSvc.Logs.ToList();
        if (selectedLeadId == null && leads.Any())
            selectedLeadId = leads[0].Id;
    }

    private void HandleDataChange()
    {
        leads = CrmSvc.Leads.ToList();
        logs = CrmSvc.Logs.ToList();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose() => CrmSvc.OnChange -= HandleDataChange;

    private string TabClass(string tab) =>
        activeTab == tab ? "bg-slate-900 text-white shadow-xs" : "text-slate-600 hover:bg-slate-100";

    private static string StatusBadgeClass(string status) => status switch
    {
        "Won" => "bg-emerald-100 text-emerald-800",
        "Qualified" => "bg-indigo-100 text-indigo-800",
        "New" => "bg-blue-100 text-blue-800",
        _ => "bg-slate-100 text-slate-700"
    };

    private static string ScoreBadgeClass(int score) => score >= 85
        ? "bg-emerald-50 text-emerald-700 border border-emerald-200"
        : score >= 70 ? "bg-amber-50 text-amber-700 border border-amber-200"
        : "bg-rose-50 text-rose-700 border border-rose-200";

    private async Task RunInstantDemo()
    {
        var targetId = leads.FirstOrDefault()?.Id ?? "lead-1";
        selectedLeadId = targetId;
        await RunParallelAgents(targetId);
    }

    private async Task RunParallelAgents(string leadId)
    {
        if (agentRunning) return;
        var lead = CrmSvc.GetLead(leadId);
        if (lead is null) return;

        agentRunning = true;
        SetAgentStates("working", 25);
        StateHasChanged();

        CrmSvc.AddLog("sales", lead.Id, lead.Name, "info", "🚀 Dispatching Sales SDR Agent to run prospect evaluation...");
        CrmSvc.AddLog("marketing", lead.Id, lead.Name, "info", "🚀 Dispatching Growth Marketing Agent to design customized funnel strategies...");
        CrmSvc.AddLog("success", lead.Id, lead.Name, "info", "🚀 Dispatching Customer Success Coach to build onboarding guidelines...");

        using var cts = new CancellationTokenSource();
        _ = RunProgressAnimation(cts.Token);

        try
        {
            if (!AiSvc.IsActive)
                await RunSimulation(lead);
            else
                await Task.WhenAll(RunSalesAgent(lead), RunMarketingAgent(lead), RunSuccessAgent(lead));
        }
        finally
        {
            cts.Cancel();
            agentRunning = false;
            SetAgentStates("completed", 100);
            await InvokeAsync(StateHasChanged);
            await Task.Delay(1500);
            SetAgentStates("idle", 0);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunProgressAnimation(CancellationToken ct)
    {
        foreach (var stage in new[] { 45, 70, 90, 100 })
        {
            try { await Task.Delay(600, ct); } catch (TaskCanceledException) { return; }
            if (ct.IsCancellationRequested) return;
            SetAgentStates("working", stage);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SetAgentStates(string status, int progress)
    {
        agentStates["sales"] = new(status, progress);
        agentStates["marketing"] = new(status, progress);
        agentStates["success"] = new(status, progress);
    }

    private async Task RunSimulation(Lead lead)
    {
        await Task.Delay(400);
        CrmSvc.AddLog("sales", lead.Id, lead.Name, "reasoning", $"[SIMULATION] Parsing prospect: '{lead.Name}', role: '{lead.Title}', budget: '{lead.Budget}'.");
        await Task.Delay(300);
        CrmSvc.AddLog("marketing", lead.Id, lead.Name, "reasoning", $"[SIMULATION] Creating drip segments targeting metrics in '{lead.Industry}'.");
        await Task.Delay(300);
        CrmSvc.AddLog("success", lead.Id, lead.Name, "reasoning", $"[SIMULATION] Mapping customer lifecycle for '{lead.Company}'.");

        await Task.Delay(800);
        var s = DemoSales(lead);
        CrmSvc.UpdateLead(lead.Id, l => { l.SalesScore = s.Score; l.SalesThought = s.Thought; l.SalesEmailDraft = s.Email; });
        CrmSvc.AddLog("sales", lead.Id, lead.Name, "output", $"[SIMULATION] SDR Evaluation Done. Score: {s.Score}", s.Email);

        await Task.Delay(600);
        var m = DemoMarketing(lead);
        CrmSvc.UpdateLead(lead.Id, l => { l.MarketingThought = m.Thought; l.MarketingPitch = m.Pitch; l.MarketingCampaign = m.Campaign; });
        CrmSvc.AddLog("marketing", lead.Id, lead.Name, "output", $"[SIMULATION] Marketing funnels completed. Pitch: \"{m.Pitch[..Math.Min(45, m.Pitch.Length)]}...\"", m.Campaign);

        await Task.Delay(600);
        var su = DemoSuccess(lead);
        CrmSvc.UpdateLead(lead.Id, l => { l.SuccessThought = su.Thought; l.SuccessChecklist = su.Checklist; l.SuccessResponse = su.Response; l.LastActionDate = DateTime.UtcNow; });
        CrmSvc.AddLog("success", lead.Id, lead.Name, "output", $"[SIMULATION] Onboarding handbook engineered. Flagged {su.Checklist.Count} steps.", su.Response);
    }

    private async Task RunSalesAgent(Lead lead)
    {
        try
        {
            CrmSvc.AddLog("sales", lead.Id, lead.Name, "reasoning", "Querying Claude for sales fit scoring and email personalization...");
            var sys = $"You are an elite AI Sales Agent (SDR). Given this lead:\nName: {lead.Name}\nCompany: {lead.Company}\nTitle: {lead.Title}\nIndustry: {lead.Industry}\nCompany Size: {lead.CompanySize}\nBudget: {lead.Budget}\nInterest: {lead.CoreProductInterest}\nTags: {string.Join(", ", lead.Tags)}\nNotes: {lead.Notes ?? "None"}\n\nReturn ONLY valid JSON: {{\"salesScore\": number, \"salesThought\": \"string\", \"salesEmailDraft\": \"string\"}}";
            var text = await AiSvc.GenerateAsync(sys, "Analyze this lead and return the evaluation JSON.");
            using var doc = JsonDocument.Parse(text);
            var root = doc.RootElement;
            CrmSvc.UpdateLead(lead.Id, l =>
            {
                l.SalesScore = root.TryGetProperty("salesScore", out var v) ? v.GetInt32() : 75;
                l.SalesThought = root.TryGetProperty("salesThought", out var t) ? t.GetString() : "Analysis complete.";
                l.SalesEmailDraft = root.TryGetProperty("salesEmailDraft", out var e) ? e.GetString() : "Email draft unavailable.";
            });
            CrmSvc.AddLog("sales", lead.Id, lead.Name, "output", $"SDR evaluation complete. Score: {CrmSvc.GetLead(lead.Id)?.SalesScore}");
        }
        catch (Exception ex)
        {
            CrmSvc.AddLog("sales", lead.Id, lead.Name, "error", $"Sales agent failed: {ex.Message}");
            var f = DemoSales(lead);
            CrmSvc.UpdateLead(lead.Id, l => { l.SalesScore = f.Score; l.SalesThought = f.Thought; l.SalesEmailDraft = f.Email; });
        }
    }

    private async Task RunMarketingAgent(Lead lead)
    {
        try
        {
            CrmSvc.AddLog("marketing", lead.Id, lead.Name, "reasoning", "Generating tailored ad copy and campaigns via Claude...");
            var sys = $"You are a creative Product Marketing Manager AI. Given this lead:\nName: {lead.Name}\nCompany: {lead.Company}\nIndustry: {lead.Industry}\nInterest: {lead.CoreProductInterest}\nTags: {string.Join(", ", lead.Tags)}\n\nReturn ONLY valid JSON: {{\"marketingThought\": \"string\", \"marketingPitch\": \"string\", \"marketingCampaign\": \"string\"}}";
            var text = await AiSvc.GenerateAsync(sys, "Formulate marketing copy matching the JSON schema.", 0.4);
            using var doc = JsonDocument.Parse(text);
            var root = doc.RootElement;
            CrmSvc.UpdateLead(lead.Id, l =>
            {
                l.MarketingThought = root.TryGetProperty("marketingThought", out var t) ? t.GetString() : "Marketing analysis complete.";
                l.MarketingPitch = root.TryGetProperty("marketingPitch", out var p) ? p.GetString() : "Automate Operations Securely.";
                l.MarketingCampaign = root.TryGetProperty("marketingCampaign", out var c) ? c.GetString() : "Step-by-step follow-ups.";
            });
            CrmSvc.AddLog("marketing", lead.Id, lead.Name, "output", $"Growth Marketing complete. Tagline: \"{CrmSvc.GetLead(lead.Id)?.MarketingPitch}\"");
        }
        catch (Exception ex)
        {
            CrmSvc.AddLog("marketing", lead.Id, lead.Name, "error", $"Marketing agent failed: {ex.Message}");
            var f = DemoMarketing(lead);
            CrmSvc.UpdateLead(lead.Id, l => { l.MarketingThought = f.Thought; l.MarketingPitch = f.Pitch; l.MarketingCampaign = f.Campaign; });
        }
    }

    private async Task RunSuccessAgent(Lead lead)
    {
        try
        {
            CrmSvc.AddLog("success", lead.Id, lead.Name, "reasoning", "Calculating custom onboarding roadmap through Claude...");
            var sys = $"You are a proactive Enterprise Customer Success Coach AI. Lead:\nName: {lead.Name}\nCompany: {lead.Company}\nIndustry: {lead.Industry}\nInterest: {lead.CoreProductInterest}\nNotes: {lead.Notes ?? "None"}\n\nReturn ONLY valid JSON: {{\"successThought\": \"string\", \"successChecklist\": [\"step1\", \"step2\", \"step3\"], \"successResponse\": \"string\"}}";
            var text = await AiSvc.GenerateAsync(sys, "Formulate onboarding strategy in JSON format.", 0.3);
            using var doc = JsonDocument.Parse(text);
            var root = doc.RootElement;
            CrmSvc.UpdateLead(lead.Id, l =>
            {
                l.SuccessThought = root.TryGetProperty("successThought", out var t) ? t.GetString() : "Success analysis complete.";
                l.SuccessChecklist = root.TryGetProperty("successChecklist", out var c) && c.ValueKind == JsonValueKind.Array
                    ? c.EnumerateArray().Select(x => x.GetString() ?? "").ToList()
                    : new() { "Setup baseline metrics" };
                l.SuccessResponse = root.TryGetProperty("successResponse", out var r) ? r.GetString() : "Welcome onboard!";
            });
            CrmSvc.AddLog("success", lead.Id, lead.Name, "output", $"Customer Success ready. {CrmSvc.GetLead(lead.Id)?.SuccessChecklist?.Count ?? 0} steps created.");
        }
        catch (Exception ex)
        {
            CrmSvc.AddLog("success", lead.Id, lead.Name, "error", $"Success agent failed: {ex.Message}");
            var f = DemoSuccess(lead);
            CrmSvc.UpdateLead(lead.Id, l => { l.SuccessThought = f.Thought; l.SuccessChecklist = f.Checklist; l.SuccessResponse = f.Response; });
        }
    }

    // Demo fallback generators
    private static (int Score, string Thought, string Email) DemoSales(Lead lead)
    {
        var score = Random.Shared.Next(65, 95);
        return (score,
            $"Analyzed company metrics for {lead.Company}. The industry of '{lead.Industry}' has clean architectural synergy. Budget '{lead.Budget}' falls within the tier criteria.",
            $"Subject: Accelerating {lead.Industry} automation at {lead.Company}\n\nHi {lead.Name},\n\nI was looking into {lead.Company}'s work in {lead.Industry}, and noticed your team is focused on {lead.CoreProductInterest}.\n\nLet's block out 15 minutes next week to share how other {lead.Title}s are running this at scale.\n\nWarm regards,\nSDR Platform Leader");
    }

    private static (string Thought, string Pitch, string Campaign) DemoMarketing(Lead lead)
    {
        return (
            $"Designing strategy based on '{lead.CoreProductInterest}' for audience in '{lead.Industry}'.",
            $"Unleash automated compliance pipelines for {lead.Industry} operations.",
            $"Active Campaign: Tech-Growth Multi-touch\n1. LinkedIn ad: 'Scaling {lead.Industry} securely'.\n2. Automation trigger sequence with Agility Checklist.\n3. Case study: 'How we helped similar compliance metrics by 210%'.");
    }

    private static (string Thought, List<string> Checklist, string Response) DemoSuccess(Lead lead)
    {
        return (
            $"Building proactive retention for {lead.Name} at {lead.Company}. Core interest: {lead.CoreProductInterest}.",
            new() {
                $"Provision custom trial account with pre-loaded {lead.Industry} dashboards",
                "Send documentation on custom webhook integration",
                "Verify compliance log reports match operational goals"
            },
            $"Hi {lead.Name},\n\nWelcome on board! As you focus on {lead.CoreProductInterest}, I have configured a personalized workspace.\n\nNo manual configuration required. I've compiled a tailored checklist for you.\n\nWarmly,\nSuccess Coach Assistant");
    }

    private void ResetLeadEvaluation(string leadId) => CrmSvc.ResetLead(leadId);

    private void UpdateLeadStatus(string leadId, string newStatus)
    {
        if (!string.IsNullOrEmpty(newStatus))
            CrmSvc.UpdateLead(leadId, l => { l.Status = newStatus; l.LastActionDate = DateTime.UtcNow; });
    }

    private void HandleAddLead()
    {
        if (string.IsNullOrWhiteSpace(newLeadModel.Name) || string.IsNullOrWhiteSpace(newLeadModel.Company) || string.IsNullOrWhiteSpace(newLeadModel.Email))
            return;

        var tags = string.IsNullOrWhiteSpace(newLeadTagsInput)
            ? new List<string> { "Inbound" }
            : newLeadTagsInput.Split(',').Select(t => t.Trim()).Where(t => !string.IsNullOrEmpty(t)).ToList();

        var lead = new Lead
        {
            Id = $"lead-{DateTimeOffset.UtcNow.ToUnixTimeMilliseconds()}",
            Name = newLeadModel.Name,
            Company = newLeadModel.Company,
            Title = string.IsNullOrWhiteSpace(newLeadModel.Title) ? "Manager" : newLeadModel.Title,
            Email = newLeadModel.Email,
            Phone = newLeadModel.Phone ?? "",
            Status = "New",
            Source = "Manual Addition",
            Budget = string.IsNullOrWhiteSpace(newLeadModel.Budget) ? "$10,000 / year" : newLeadModel.Budget,
            CompanySize = newLeadModel.CompanySize,
            Industry = newLeadModel.Industry,
            CoreProductInterest = newLeadModel.CoreProductInterest,
            Notes = newLeadModel.Notes,
            Tags = tags,
            LastActionDate = DateTime.UtcNow
        };

        var added = CrmSvc.AddLead(lead);
        selectedLeadId = added.Id;
        showAddModal = false;
        newLeadModel = new() { Industry = "Technology", CompanySize = "50-100 employees", Budget = "$25,000 / year" };
        newLeadTagsInput = "";
    }

    private void HandleDeleteLead(string leadId)
    {
        _ = InvokeAsync(async () =>
        {
            if (await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this lead?"))
            {
                CrmSvc.DeleteLead(leadId);
                if (selectedLeadId == leadId) selectedLeadId = null;
            }
        });
    }

    private void CopyToClipboard(string text)
    {
        _ = JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }
}
